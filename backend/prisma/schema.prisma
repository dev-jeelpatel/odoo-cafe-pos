generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum SessionStatus {
  OPEN
  CLOSED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  DISABLED
}

enum OrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum KitchenStatus {
  PENDING
  TO_COOK
  PREPARING
  COMPLETED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  TEST
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum PromotionType {
  PRODUCT
  ORDER
}

enum ProductUnit {
  PIECE
  KG
  LITER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PAYMENT
  SESSION_OPEN
  SESSION_CLOSE
}

// ─── Inventory Enums ──────────────────────────────────────────────────────────

enum InventoryUnit {
  G
  KG
  ML
  L
  PCS
  DOZEN
}

enum StockMovementType {
  ORDER_DEDUCTION
  ORDER_RESTORE
  PURCHASE
  WASTAGE
  ADJUSTMENT
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CANCELLED
}

enum BatchStatus {
  ACTIVE
  EXPIRED
  CONSUMED
}

enum AdjustmentType {
  ADD
  REMOVE
  SET
}

enum AdjustmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WastageStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WastageShift {
  MORNING
  AFTERNOON
  EVENING
}

enum NotificationPriority {
  CRITICAL
  HIGH
  MEDIUM
  INFO
}

enum NotificationType {
  LOW_STOCK
  OUT_OF_STOCK
  EXPIRING_SOON
  EXPIRED
  HIGH_WASTAGE
  PO_PENDING
  GRN_RECEIVED
  MANUAL_ADJUSTMENT
  WASTAGE_APPROVED
  REORDER_LEVEL
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(EMPLOYEE)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders     Order[]
  sessions   Session[]
  auditLogs  AuditLog[]

  // Inventory relations
  purchaseOrdersCreated PurchaseOrder[]    @relation("POCreatedBy")
  grnsReceived          GoodsReceivedNote[] @relation("GRNReceivedBy")
  stockMovements        StockMovement[]    @relation("MovementCreatedBy")
  adjustmentsRequested  StockAdjustment[]  @relation("AdjRequestedBy")
  adjustmentsApproved   StockAdjustment[]  @relation("AdjApprovedBy")
  wastageReported       WastageEntry[]     @relation("WastageReportedBy")
  wastageApproved       WastageEntry[]     @relation("WastageApprovedBy")
  invNotifications      InvNotification[]  @relation("InvNotifUser")

  @@index([email])
}

model Session {
  id             String        @id @default(cuid())
  userId         String
  openedAt       DateTime      @default(now())
  closedAt       DateTime?
  openingAmount  Float         @default(0)
  closingAmount  Float         @default(0)
  status         SessionStatus @default(OPEN)

  // Summary snapshot (populated on close)
  totalSales        Float @default(0)
  totalOrders       Int   @default(0)
  cashAmount        Float @default(0)
  upiAmount         Float @default(0)
  cardAmount        Float @default(0)
  taxCollected      Float @default(0)
  discountsApplied  Float @default(0)

  user   User    @relation(fields: [userId], references: [id])
  orders Order[]

  @@index([userId])
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  color    String    @default("#6366f1")
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  name        String
  categoryId  String
  price       Float
  unit        ProductUnit @default(PIECE)
  tax         Float       @default(0)
  description String      @default("")
  imageUrl    String?
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  category       Category    @relation(fields: [categoryId], references: [id])
  orderItems     OrderItem[]
  promotions     Promotion[] @relation("PromotionProduct")
  recipe         Recipe?

  @@index([name])
  @@index([categoryId])
}

model Floor {
  id     String  @id @default(cuid())
  name   String  @unique
  tables Table[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Table {
  id          String      @id @default(cuid())
  floorId     String
  tableNumber String
  seats       Int
  status      TableStatus @default(AVAILABLE)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  floor  Floor   @relation(fields: [floorId], references: [id])
  orders Order[]

  @@index([floorId])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String   @default("")
  phone     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@index([email])
  @@index([phone])
}

model Order {
  id             String        @id @default(cuid())
  orderNumber    String        @unique
  customerId     String?
  tableId        String?
  employeeId     String?
  sessionId      String?
  orderType      OrderType     @default(DINE_IN)
  status         OrderStatus   @default(DRAFT)
  kitchenStatus  KitchenStatus @default(PENDING)
  notes          String        @default("")
  subtotal       Float         @default(0)
  taxAmount      Float         @default(0)
  discountAmount Float         @default(0)
  totalAmount    Float         @default(0)
  isPaid         Boolean       @default(false)
  couponCode     String?
  promotionId    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customer   Customer?   @relation(fields: [customerId], references: [id])
  table      Table?      @relation(fields: [tableId], references: [id])
  employee   User?       @relation(fields: [employeeId], references: [id])
  session    Session?    @relation(fields: [sessionId], references: [id])
  promotion  Promotion?  @relation(fields: [promotionId], references: [id])

  items      OrderItem[]
  payments   Payment[]
  receipts   Receipt[]

  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
  @@index([sessionId])
  @@index([kitchenStatus])
}

model OrderItem {
  id            String        @id @default(cuid())
  orderId       String
  productId     String
  productName   String
  categoryColor String?
  quantity      Int
  unitPrice     Float
  totalPrice    Float
  tax           Float         @default(0)
  kitchenCompleted Boolean    @default(false)
  itemStatus    OrderStatus   @default(PENDING)
  createdAt     DateTime      @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  paymentMethod   PaymentMethod
  amount          Float
  transactionId   String?
  referenceNumber String?
  paymentStatus   PaymentStatus @default(PENDING)
  paidAt          DateTime?
  createdAt       DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Float
  active        Boolean      @default(true)
  expiryDate    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Promotion {
  id              String        @id @default(cuid())
  name            String
  promotionType   PromotionType
  conditionProductId String?
  minQuantity     Int?
  minOrderAmount  Float?
  discountType    DiscountType
  discountValue   Float
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  conditionProduct Product? @relation("PromotionProduct", fields: [conditionProductId], references: [id])
  orders          Order[]
}

model PaymentMethodConfig {
  id        String        @id @default(cuid())
  method    PaymentMethod @unique
  label     String
  enabled   Boolean       @default(true)
  upiId     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Receipt {
  id            String   @id @default(cuid())
  orderId       String
  receiptNumber String   @unique
  receiptData   Json?
  createdAt     DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String?
  details    Json?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])
}

// ─── Inventory Models ─────────────────────────────────────────────────────────

model InventoryCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  color       String   @default("#6366f1")
  icon        String   @default("Package")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items InventoryItem[]
}

model Supplier {
  id            String   @id @default(cuid())
  name          String
  contactPerson String   @default("")
  phone         String   @default("")
  email         String   @default("")
  address       String   @default("")
  gstNumber     String   @default("")
  paymentTerms  String   @default("")
  active        Boolean  @default(true)
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  items          InventoryItem[]
  purchaseOrders PurchaseOrder[]
  batches        InventoryBatch[]
}

model InventoryItem {
  id              String        @id @default(cuid())
  name            String
  sku             String        @unique
  categoryId      String
  unit            InventoryUnit @default(PCS)
  currentStock    Float         @default(0)
  minStock        Float         @default(0)
  maxStock        Float?
  unitCost        Float         @default(0)
  supplierId      String?
  shelfLifeDays   Int?
  storageLocation String        @default("")
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  category        InventoryCategory  @relation(fields: [categoryId], references: [id])
  supplier        Supplier?          @relation(fields: [supplierId], references: [id])
  batches         InventoryBatch[]
  movements       StockMovement[]
  adjustments     StockAdjustment[]
  wastageEntries  WastageEntry[]
  recipeItems     RecipeIngredient[]
  poItems         PurchaseOrderItem[]
  grnItems        GRNItem[]

  @@index([categoryId])
  @@index([supplierId])
  @@index([active])
}

model InventoryBatch {
  id            String      @id @default(cuid())
  inventoryItemId String
  batchNumber   String
  quantity      Float
  purchaseDate  DateTime    @default(now())
  expiryDate    DateTime?
  supplierId    String?
  unitCost      Float       @default(0)
  status        BatchStatus @default(ACTIVE)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  supplier      Supplier?     @relation(fields: [supplierId], references: [id])

  @@index([inventoryItemId])
  @@index([expiryDate])
  @@index([status])
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  poNumber     String              @unique
  supplierId   String
  status       PurchaseOrderStatus @default(DRAFT)
  expectedDate DateTime?
  totalAmount  Float               @default(0)
  notes        String              @default("")
  createdBy    String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  createdByUser User            @relation("POCreatedBy", fields: [createdBy], references: [id])
  items     PurchaseOrderItem[]
  grns      GoodsReceivedNote[]

  @@index([supplierId])
  @@index([status])
}

model PurchaseOrderItem {
  id              String @id @default(cuid())
  poId            String
  inventoryItemId String
  quantity        Float
  unitPrice       Float
  totalPrice      Float

  purchaseOrder PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([poId])
}

model GoodsReceivedNote {
  id               String   @id @default(cuid())
  grnNumber        String   @unique
  poId             String
  receivedDate     DateTime @default(now())
  receivedBy       String
  notes            String   @default("")
  discrepancyNotes String   @default("")
  createdAt        DateTime @default(now())

  purchaseOrder   PurchaseOrder @relation(fields: [poId], references: [id])
  receivedByUser  User          @relation("GRNReceivedBy", fields: [receivedBy], references: [id])
  items           GRNItem[]

  @@index([poId])
}

model GRNItem {
  id              String   @id @default(cuid())
  grnId           String
  inventoryItemId String
  orderedQty      Float
  receivedQty     Float
  unitPrice       Float
  batchNumber     String   @default("")
  expiryDate      DateTime?

  grn           GoodsReceivedNote @relation(fields: [grnId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem     @relation(fields: [inventoryItemId], references: [id])

  @@index([grnId])
}

model StockMovement {
  id              String            @id @default(cuid())
  inventoryItemId String
  type            StockMovementType
  quantity        Float
  stockBefore     Float
  stockAfter      Float
  referenceType   String?
  referenceId     String?
  createdBy       String
  createdAt       DateTime          @default(now())

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  createdByUser User          @relation("MovementCreatedBy", fields: [createdBy], references: [id])

  @@index([inventoryItemId])
  @@index([referenceId])
  @@index([createdAt])
}

model StockAdjustment {
  id              String           @id @default(cuid())
  inventoryItemId String
  type            AdjustmentType
  quantity        Float
  reason          String
  referenceNumber String           @default("")
  notes           String           @default("")
  status          AdjustmentStatus @default(PENDING)
  requestedBy     String
  approvedBy      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  requestedByUser User        @relation("AdjRequestedBy", fields: [requestedBy], references: [id])
  approvedByUser  User?       @relation("AdjApprovedBy", fields: [approvedBy], references: [id])

  @@index([inventoryItemId])
  @@index([status])
}

model Recipe {
  id        String   @id @default(cuid())
  productId String   @unique
  name      String
  yield     Float    @default(1)
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  product     Product            @relation(fields: [productId], references: [id])
  ingredients RecipeIngredient[]
}

model RecipeIngredient {
  id              String @id @default(cuid())
  recipeId        String
  inventoryItemId String
  quantity        Float
  unit            String
  notes           String @default("")

  recipe        Recipe        @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([recipeId])
}

model WastageReason {
  id          String   @id @default(cuid())
  name        String   @unique
  description String   @default("")
  category    String   @default("")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  wastageEntries WastageEntry[]
}

model WastageEntry {
  id              String        @id @default(cuid())
  inventoryItemId String
  date            DateTime      @default(now())
  quantity        Float
  unit            String
  reasonId        String
  cost            Float         @default(0)
  notes           String        @default("")
  imageUrl        String?
  reportedBy      String
  shift           WastageShift  @default(MORNING)
  status          WastageStatus @default(PENDING)
  approvedBy      String?
  approvedAt      DateTime?
  rejectionReason String        @default("")
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  inventoryItem  InventoryItem  @relation(fields: [inventoryItemId], references: [id])
  reason         WastageReason  @relation(fields: [reasonId], references: [id])
  reportedByUser User           @relation("WastageReportedBy", fields: [reportedBy], references: [id])
  approvedByUser User?          @relation("WastageApprovedBy", fields: [approvedBy], references: [id])

  @@index([inventoryItemId])
  @@index([status])
  @@index([date])
}

model InvNotification {
  id                String               @id @default(cuid())
  type              NotificationType
  title             String
  message           String
  priority          NotificationPriority @default(INFO)
  relatedEntityType String?
  relatedEntityId   String?
  userId            String
  read              Boolean              @default(false)
  createdAt         DateTime             @default(now())

  user User @relation("InvNotifUser", fields: [userId], references: [id])

  @@index([userId, read])
  @@index([createdAt])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  EMPLOYEE
}

enum SessionStatus {
  OPEN
  CLOSED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  DISABLED
}

enum OrderStatus {
  DRAFT
  PENDING
  CONFIRMED
  PREPARING
  READY
  SERVED
  COMPLETED
  CANCELLED
}

enum KitchenStatus {
  PENDING
  TO_COOK
  PREPARING
  COMPLETED
}

enum OrderType {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  TEST
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum PromotionType {
  PRODUCT
  ORDER
}

enum ProductUnit {
  PIECE
  KG
  LITER
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PAYMENT
  SESSION_OPEN
  SESSION_CLOSE
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(EMPLOYEE)
  archived  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders     Order[]
  sessions   Session[]
  auditLogs  AuditLog[]

  @@index([email])
}

model Session {
  id             String        @id @default(cuid())
  userId         String
  openedAt       DateTime      @default(now())
  closedAt       DateTime?
  openingAmount  Float         @default(0)
  closingAmount  Float         @default(0)
  status         SessionStatus @default(OPEN)

  // Summary snapshot (populated on close)
  totalSales        Float @default(0)
  totalOrders       Int   @default(0)
  cashAmount        Float @default(0)
  upiAmount         Float @default(0)
  cardAmount        Float @default(0)
  taxCollected      Float @default(0)
  discountsApplied  Float @default(0)

  user   User    @relation(fields: [userId], references: [id])
  orders Order[]

  @@index([userId])
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  color    String    @default("#6366f1")
  products Product[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String      @id @default(cuid())
  name        String
  categoryId  String
  price       Float
  unit        ProductUnit @default(PIECE)
  tax         Float       @default(0)
  description String      @default("")
  imageUrl    String?
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  category       Category    @relation(fields: [categoryId], references: [id])
  orderItems     OrderItem[]
  promotions     Promotion[] @relation("PromotionProduct")

  @@index([name])
  @@index([categoryId])
}

model Floor {
  id     String  @id @default(cuid())
  name   String  @unique
  tables Table[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Table {
  id          String      @id @default(cuid())
  floorId     String
  tableNumber String
  seats       Int
  status      TableStatus @default(AVAILABLE)
  active      Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  floor  Floor   @relation(fields: [floorId], references: [id])
  orders Order[]

  @@index([floorId])
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  email     String   @default("")
  phone     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders Order[]

  @@index([email])
  @@index([phone])
}

model Order {
  id             String        @id @default(cuid())
  orderNumber    String        @unique
  customerId     String?
  tableId        String?
  employeeId     String?
  sessionId      String?
  orderType      OrderType     @default(DINE_IN)
  status         OrderStatus   @default(DRAFT)
  kitchenStatus  KitchenStatus @default(PENDING)
  notes          String        @default("")
  subtotal       Float         @default(0)
  taxAmount      Float         @default(0)
  discountAmount Float         @default(0)
  totalAmount    Float         @default(0)
  isPaid         Boolean       @default(false)
  couponCode     String?
  promotionId    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  customer   Customer?   @relation(fields: [customerId], references: [id])
  table      Table?      @relation(fields: [tableId], references: [id])
  employee   User?       @relation(fields: [employeeId], references: [id])
  session    Session?    @relation(fields: [sessionId], references: [id])
  promotion  Promotion?  @relation(fields: [promotionId], references: [id])

  items      OrderItem[]
  payments   Payment[]
  receipts   Receipt[]

  @@index([orderNumber])
  @@index([status])
  @@index([createdAt])
  @@index([sessionId])
  @@index([kitchenStatus])
}

model OrderItem {
  id            String        @id @default(cuid())
  orderId       String
  productId     String
  productName   String
  categoryColor String?
  quantity      Int
  unitPrice     Float
  totalPrice    Float
  tax           Float         @default(0)
  kitchenCompleted Boolean    @default(false)
  itemStatus    OrderStatus   @default(PENDING)
  createdAt     DateTime      @default(now())

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id              String        @id @default(cuid())
  orderId         String
  paymentMethod   PaymentMethod
  amount          Float
  transactionId   String?
  referenceNumber String?
  paymentStatus   PaymentStatus @default(PENDING)
  paidAt          DateTime?
  createdAt       DateTime      @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Coupon {
  id            String       @id @default(cuid())
  code          String       @unique
  discountType  DiscountType
  discountValue Float
  active        Boolean      @default(true)
  expiryDate    DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Promotion {
  id              String        @id @default(cuid())
  name            String
  promotionType   PromotionType
  conditionProductId String?
  minQuantity     Int?
  minOrderAmount  Float?
  discountType    DiscountType
  discountValue   Float
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  conditionProduct Product? @relation("PromotionProduct", fields: [conditionProductId], references: [id])
  orders          Order[]
}

model PaymentMethodConfig {
  id        String        @id @default(cuid())
  method    PaymentMethod @unique
  label     String
  enabled   Boolean       @default(true)
  upiId     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Receipt {
  id            String   @id @default(cuid())
  orderId       String
  receiptNumber String   @unique
  receiptData   Json?
  createdAt     DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?
  action     AuditAction
  entityType String
  entityId   String?
  details    Json?
  createdAt  DateTime    @default(now())

  user User? @relation(fields: [userId], references: [id])
}
